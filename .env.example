# ─────────────────────────────────────────────────────────────────
# AI Lab — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Model Selection ─────────────────────────────────────────────
# Strategic planner (o1, o1-pro, o3, etc.)
STRATEGIC_MODEL=o1

# Mid-tier project loop model (cheaper, faster)
PROJECT_MODEL=gpt-4o

# Worker / execution model (cheapest/fastest, can be local)
WORKER_MODEL=gpt-4o-mini

# ── Optional: Ollama local model (for the worker loop) ──────────
# OLLAMA_BASE_URL=http://localhost:11434
# LOCAL_WORKER_MODEL=llama3

# ── Optional: Anthropic (for alternate critic/project models) ───
# ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Loop Safety Guards ───────────────────────────────────────────
# Max total project loop iterations before hard stop
MAX_PROJECT_ITERATIONS=200

# Max strategic replans allowed for one task before manual intervention
MAX_STRATEGIC_REPLANS_PER_TASK=3

# ─────────────────────────────────────────────────────────────────
# AI Lab — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── OpenAI (required for O1 strategic calls) ─────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Model Selection ─────────────────────────────────────────────
# Strategic planner (o1, o1-pro, o3 — expensive, called rarely)
STRATEGIC_MODEL=o1

# Mid-tier project/critic model
PROJECT_MODEL=gpt-4o

# Worker / execution model (cheapest/fastest)
WORKER_MODEL=gpt-4o-mini

# ── O1 Settings ─────────────────────────────────────────────────
O1_MAX_TOKENS=8000
# Reasoning depth: low | medium | high
O1_REASONING_EFFORT=high

# ── Ollama (local worker tier — $0, unlimited) ──────────────────
# Enable to use local models for the worker loop
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_WORKER_MODEL=llama3.3:70b

# ── Google Gemini (optional medium/critic tier — ~$0.001/call) ──
# GEMINI_API_KEY=...your-key-here...
# GEMINI_MODEL=gemini-2.5-flash

# ── Anthropic (optional — for alternate critic/project models) ──
# ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# ── Loop Safety Guards ───────────────────────────────────────────
# Worker failures before escalating to O1 for diagnosis
ESCALATE_THRESHOLD=5

# Max experiments per project loop iteration
MAX_EXPERIMENTS=20

# Max total project loop iterations before hard stop
MAX_PROJECT_ITERATIONS=200

# Max strategic replans allowed for one task before manual intervention
MAX_STRATEGIC_REPLANS_PER_TASK=3
